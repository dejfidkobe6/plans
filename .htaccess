Options -Indexes

# Increase limits for large floor plan file uploads
LimitRequestBody 0

<IfModule mod_php8.c>
  php_value upload_max_filesize 50M
  php_value post_max_size       52M
</IfModule>
<IfModule mod_php7.c>
  php_value upload_max_filesize 50M
  php_value post_max_size       52M
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # api/ soubory servíruj přímo – nepřesměrovávat
  RewriteRule ^api/ - [L]

  # Existující soubory a složky servíruj přímo
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Vše ostatní → index.html
  RewriteRule ^ index.html [L]
</IfModule>

# Bezpečnostní hlavičky
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Zakázat přístup k citlivým souborům
<FilesMatch "\.(sql|md)$">
  Require all denied
</FilesMatch>
